# Скопируй в .env и заполни. Загружай в окружение перед запуском, напр.:
#   set -a; source .env; set +a; go run ./cmd/bot
#
# Обязателен только TELEGRAM_TOKEN. Креды провайдеров ниже НЕОБЯЗАТЕЛЬНЫ:
# они используются только для ОДНОРАЗОВОГО сида таблицы accounts при первом
# старте (если она пуста). Дальше аккаунты живут в SQL и управляются командами
# бота (/addaccount, /accounts, ...), а несколько аккаунтов на тип добавляются
# уже через бота. После первого старта токены из env можно убрать.

# Telegram
TELEGRAM_TOKEN=

# Timeweb Cloud (панель → API и Terraform)
TIMEWEB_TOKEN=

# VK Cloud (Application Credential)
VK_APP_CRED_ID=
VK_APP_CRED_SECRET=
VK_EXT_NET_ID=

# Selectel (сервисный пользователь, project-scoped)
SEL_ACCOUNT_ID=
SEL_SERVICE_USER=
SEL_SERVICE_PASSWORD=
SEL_PROJECT_ID=
SEL_EXT_NET_ID=

# Gcore
GCORE_API_TOKEN=
GCORE_PROJECT_ID=

# MWS Cloud
MWS_TOKEN=
MWS_PROJECT_ID=
MWS_NETWORK_ID=
MWS_SUBNET_ID=

# RuVDS
RUVDS_TOKEN=
RUVDS_SERVER_ID=

# Beget
BEGET_TOKEN=
BEGET_SERVER_ID=

# Скопируй в .env и заполни. Загружай в окружение перед запуском, напр.:
#   set -a; source .env; set +a; go run ./cmd/bot
#
# Обязателен только TELEGRAM_TOKEN. Креды провайдеров ниже НЕОБЯЗАТЕЛЬНЫ:
# они используются только для ОДНОРАЗОВОГО сида таблицы accounts при первом
# старте (если она пуста). Дальше аккаунты живут в SQL и управляются командами
# бота (/addaccount, /accounts, ...), а несколько аккаунтов на тип добавляются
# уже через бота. После первого старта токены из env можно убрать.

# Telegram
TELEGRAM_TOKEN=

# Кто АДМИН бота (управляет аккаунтами и whitelist'ом). ID через запятую.
# Свой Telegram ID узнай у @userinfobot или @getmyid_bot. Пример: 123456789,987654321
# Это то же самое, что telegram.admin_user_ids в config.yaml — env просто удобнее.
TELEGRAM_ADMIN_IDS=
# Кто просто может ПОЛЬЗОВАТЬСЯ ботом (не админ). ID через запятую. Пусто = только админы.
# Если и админы, и allowed, и whitelist пусты — бот отвечает ВСЕМ (небезопасно).
TELEGRAM_ALLOWED_IDS=

# Форум-группа для логов ловли IP (по топикам на аккаунт). ID супергруппы (-100...).
# Бот должен быть в группе админом с правом «Управление темами», в группе включены Топики.
# Если задано — уведомления включаются автоматически. Пусто = выключены.
NOTIFY_CHAT_ID=

# Timeweb Cloud (панель → API и Terraform)
TIMEWEB_TOKEN=

# VK Cloud (Application Credential)
VK_APP_CRED_ID=
VK_APP_CRED_SECRET=
VK_EXT_NET_ID=

# Selectel (сервисный пользователь, project-scoped)
SEL_ACCOUNT_ID=
SEL_SERVICE_USER=
SEL_SERVICE_PASSWORD=
SEL_PROJECT_ID=
SEL_EXT_NET_ID=

# Gcore
GCORE_API_TOKEN=
GCORE_PROJECT_ID=

# MWS Cloud
MWS_TOKEN=
MWS_PROJECT_ID=
MWS_NETWORK_ID=
MWS_SUBNET_ID=

# RuVDS
RUVDS_TOKEN=
RUVDS_SERVER_ID=

# Beget
BEGET_TOKEN=
BEGET_SERVER_ID=
